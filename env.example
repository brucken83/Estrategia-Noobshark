# Ativos e timeframe
SYMBOLS=BTCUSDT,ETHUSDT
TIMEFRAME=15m

# Capital inicial da simulação
INITIAL_EQUITY=100000

# Risco base
RISK_PCT=0.005
BASE_RISK_PCT=0.005
MEDIUM_RISK_PCT=0.0035
LOW_RISK_PCT=0.002
MIN_SENTIMENT_SCORE=3

# Gestão da posição
TP1_PCT=0.40
TP2_PCT=0.25
TP3_PCT=0.25
RUNNER_PCT=0.10
ATR_MULT=1.0

# Dados e indicadores
MAX_BARS=500
VWAP_WHALE_MULT=2.0
POC_BINS=40
ENTRY_OFFSET_BPS=0
ENABLE_SENTIMENT=true

# Arquivos
STATE_FILE=runtime_state.json
OUTPUT_JSON=docs/data/latest.json

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CoinGlass
COINGLASS_API_KEY=
COINGLASS_BASE_URL=https://open-api-v4.coinglass.com/api
COINGLASS_INTERVAL=4h

# Binance
BINANCE_MARKET_TYPE=spot
